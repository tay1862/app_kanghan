generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  displayName  String    @map("display_name") @db.VarChar(100)
  role         UserRole  @default(staff)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  bookings        Booking[]
  foodOrders      FoodOrder[]
  playlists       Playlist[]
  playlistSongs   PlaylistSong[]
  musicQueue      MusicQueue[]
  bookingPayments BookingPayment[]

  @@map("users")
}

enum UserRole {
  admin
  staff
}

model RoomType {
  id          Int            @id @default(autoincrement())
  name        String         @db.VarChar(100)
  description String?        @db.Text
  basePrice   Decimal        @map("base_price") @db.Decimal(12, 2)
  maxGuests   Int            @default(2) @map("max_guests")
  category    RoomCategory
  amenities   Json?
  imageUrl    String?        @map("image_url") @db.VarChar(500)
  sortOrder   Int            @default(0) @map("sort_order")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  rooms Room[]

  @@map("room_types")
}

enum RoomCategory {
  room
  camping_own_tent
  camping_resort_tent
}

model Room {
  id         Int        @id @default(autoincrement())
  roomTypeId Int        @map("room_type_id")
  roomNumber String     @unique @map("room_number") @db.VarChar(20)
  floor      String?    @db.VarChar(10)
  status     RoomStatus @default(available)
  notes      String?    @db.Text
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  roomType RoomType  @relation(fields: [roomTypeId], references: [id])
  bookings Booking[]

  @@index([roomTypeId])
  @@index([status])
  @@map("rooms")
}

enum RoomStatus {
  available
  occupied
  maintenance
}

model Booking {
  id              Int            @id @default(autoincrement())
  invoiceNumber   String         @unique @map("invoice_number") @db.VarChar(20)
  roomId          Int            @map("room_id")
  guestName       String         @map("guest_name") @db.VarChar(200)
  guestPhone      String         @map("guest_phone") @db.VarChar(30)
  guestNotes      String?        @map("guest_notes") @db.Text
  checkIn         DateTime       @map("check_in") @db.Date
  checkOut        DateTime       @map("check_out") @db.Date
  numGuests       Int            @default(1) @map("num_guests")
  nightPrice      Decimal        @map("night_price") @db.Decimal(12, 2)
  totalNights     Int            @map("total_nights")
  subtotal        Decimal        @db.Decimal(12, 2)
  discountAmount  Decimal        @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(12, 2)
  depositPercent  Decimal?       @map("deposit_percent") @db.Decimal(5, 2)
  depositAmount   Decimal        @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  depositMethod   PaymentMethod? @map("deposit_method")
  remainingAmount Decimal        @map("remaining_amount") @db.Decimal(12, 2)
  status          BookingStatus  @default(confirmed)
  paymentStatus   PaymentStatus  @default(pending)
  createdBy       Int            @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  room     Room             @relation(fields: [roomId], references: [id])
  creator  User             @relation(fields: [createdBy], references: [id])
  payments BookingPayment[]

  @@index([roomId, checkIn, checkOut])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@map("bookings")
}

enum BookingStatus {
  confirmed
  checked_in
  checked_out
  cancelled
}

enum PaymentStatus {
  pending
  partial
  paid
}

enum PaymentMethod {
  cash
  transfer
  other
}

model BookingPayment {
  id        Int           @id @default(autoincrement())
  bookingId Int           @map("booking_id")
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  note      String?       @db.VarChar(500)
  paidAt    DateTime      @default(now()) @map("paid_at")
  createdBy Int           @map("created_by")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([bookingId])
  @@map("booking_payments")
}

model FoodOrder {
  id              Int               @id @default(autoincrement())
  invoiceNumber   String            @unique @map("invoice_number") @db.VarChar(20)
  customerName    String?           @map("customer_name") @db.VarChar(200)
  customerPhone   String?           @map("customer_phone") @db.VarChar(30)
  orderType       FoodOrderType     @map("order_type")
  eventDate       DateTime?         @map("event_date") @db.Date
  numTables       Int?              @map("num_tables")
  numGuests       Int?              @map("num_guests")
  subtotal        Decimal           @db.Decimal(12, 2)
  discountAmount  Decimal           @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount     Decimal           @map("total_amount") @db.Decimal(12, 2)
  depositAmount   Decimal           @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  remainingAmount Decimal           @map("remaining_amount") @db.Decimal(12, 2)
  paymentStatus   PaymentStatus     @default(pending) @map("payment_status")
  status          FoodOrderStatus   @default(draft)
  notes           String?           @db.Text
  createdBy       Int               @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  creator User            @relation(fields: [createdBy], references: [id])
  items   FoodOrderItem[]

  @@index([status])
  @@index([createdAt])
  @@map("food_orders")
}

enum FoodOrderType {
  banquet
  ala_carte
  mixed
}

enum FoodOrderStatus {
  draft
  confirmed
  completed
  cancelled
}

model FoodOrderItem {
  id          Int     @id @default(autoincrement())
  foodOrderId Int     @map("food_order_id")
  name        String  @db.VarChar(200)
  quantity    Decimal @db.Decimal(10, 2)
  unit        String  @default("ອັນ") @db.VarChar(50)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  notes       String? @db.VarChar(500)
  sortOrder   Int     @default(0) @map("sort_order")

  foodOrder FoodOrder @relation(fields: [foodOrderId], references: [id], onDelete: Cascade)

  @@index([foodOrderId])
  @@map("food_order_items")
}

model FoodMenuPreset {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(200)
  defaultPrice Decimal @map("default_price") @db.Decimal(12, 2)
  unit         String  @default("ອັນ") @db.VarChar(50)
  category     String? @db.VarChar(100)
  isActive     Boolean @default(true) @map("is_active")

  @@map("food_menu_presets")
}

model Playlist {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdBy   Int      @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User           @relation(fields: [createdBy], references: [id])
  songs   PlaylistSong[]

  @@map("playlists")
}

model PlaylistSong {
  id           Int      @id @default(autoincrement())
  playlistId   Int      @map("playlist_id")
  title        String   @db.VarChar(300)
  youtubeId    String   @map("youtube_id") @db.VarChar(20)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  duration     Int?
  sortOrder    Int      @default(0) @map("sort_order")
  addedBy      Int      @map("added_by")
  addedAt      DateTime @default(now()) @map("added_at")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [addedBy], references: [id])

  @@index([playlistId])
  @@map("playlist_songs")
}

model MusicQueue {
  id           Int              @id @default(autoincrement())
  youtubeId    String           @map("youtube_id") @db.VarChar(20)
  title        String           @db.VarChar(300)
  thumbnailUrl String?          @map("thumbnail_url") @db.VarChar(500)
  duration     Int?
  position     Int
  status       MusicQueueStatus @default(pending)
  addedBy      Int              @map("added_by")
  addedAt      DateTime         @default(now()) @map("added_at")

  creator User @relation(fields: [addedBy], references: [id])

  @@index([status])
  @@index([position])
  @@map("music_queue")
}

enum MusicQueueStatus {
  pending
  playing
  played
  skipped
}

model MenuPage {
  id        Int      @id @default(autoincrement())
  title     String?  @db.VarChar(200)
  imageUrl  String   @map("image_url") @db.VarChar(500)
  sortOrder Int      @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("menu_pages")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
